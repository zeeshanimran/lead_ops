generator client {
  provider        = "prisma-client-js"
  engineType      = "client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  BD
  CLOSER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum JobStatus {
  NOT_APPLIED
  APPLIED
}

enum LeadNature {
  W2
  CONTRACT
  C2C
}

enum ProofType {
  EMAIL_LINK
  SCREENSHOT
  MANUAL_VERIFICATION
}

enum LeadStatus {
  PENDING_APPROVAL
  APPROVED
  READY_TO_SCHEDULE
  CALL_SCHEDULED
  IN_PROGRESS
  NEXT_CALL_REQUIRED
  OFFERED
  REJECTED
  CLOSED
  DISMISSED
}

enum LeadCallStatus {
  SCHEDULED
  COMPLETED
  PENDING_FEEDBACK
  NO_SHOW
  RESCHEDULED
  CANCELLED
}

enum ManualInviteStatus {
  MANUAL_INVITE_PENDING
  MANUAL_INVITE_CREATED
  ACCEPTED
  DECLINED
  REMINDER_DUE
}

enum FeedbackCallStatus {
  TAKEN
  RESCHEDULED
  NO_SHOW
  SHIFTED
}

enum FeedbackResult {
  PASSED
  FAILED
  NEED_NEXT_CALL
  OFFERED
  REJECTED
  NO_DECISION
}

enum CallStage {
  SCREENING
  FIRST
  SECOND
  THIRD
  FOURTH
  FIFTH
  FINAL
  OFFERED
}

enum CallNature {
  PHONE_SCREENING
  FIRST_INTERVIEW
  TECHNICAL_ROUND
  PANEL_INTERVIEW
  CULTURE_FIT
  FINAL_PANEL
  OFFER_CALL
}

model User {
  id                   String      @id @default(cuid())
  name                 String
  email                String      @unique
  passwordHash         String
  role                 Role
  status               UserStatus  @default(ACTIVE)
  refreshTokenHash     String?
  invitationTokenHash  String?     @unique
  invitationSentAt     DateTime?
  invitationExpiresAt  DateTime?
  invitationAcceptedAt DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  deletedAt            DateTime?

  bdJobs               Job[]       @relation("BdJobs")
  createdLeads         Lead[]      @relation("CreatedBdLeads")
  assignedLeads        Lead[]      @relation("AssignedBdLeads")
  approvedLeads        Lead[]      @relation("ApprovedAdminLeads")
  scheduledCalls       LeadCall[]  @relation("ScheduledBdCalls")
  assignedCalls        LeadCall[]  @relation("CloserLeadCalls")
  callFeedback         CallFeedback[]
  leadTimeline         LeadTimeline[]
  auditLogs            AuditLog[]
}

model Job {
  id             String    @id @default(cuid())
  jobId          String    @unique
  dateAdded      DateTime  @default(now())
  platform       String
  companyName    String
  techStack      String
  jobLink        String
  jobDescription String
  status         JobStatus @default(NOT_APPLIED)
  appliedAt      DateTime?
  bdUserId       String
  bd             User      @relation("BdJobs", fields: [bdUserId], references: [id])
  leads          Lead[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([bdUserId])
  @@index([dateAdded])
}

model TechStack {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  leads       Lead[]
}

model Lead {
  id                String      @id @default(cuid())
  companyName       String
  profileName       String
  resumeUrl         String?
  nature            LeadNature
  techStackId       String
  payrate           String
  proofType         ProofType
  proofNotes        String?
  proofUrl          String?
  jobId             String?
  createdByBdId     String
  assignedBdId      String?
  approvedByAdminId String?
  status            LeadStatus  @default(PENDING_APPROVAL)
  currentStage      CallStage?
  adminNotes        String?
  dismissalReason   String?
  approvedAt        DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  createdByBd       User        @relation("CreatedBdLeads", fields: [createdByBdId], references: [id])
  assignedBd        User?       @relation("AssignedBdLeads", fields: [assignedBdId], references: [id])
  approvedByAdmin   User?       @relation("ApprovedAdminLeads", fields: [approvedByAdminId], references: [id])
  job               Job?        @relation(fields: [jobId], references: [id])
  techStack         TechStack   @relation(fields: [techStackId], references: [id])
  calls             LeadCall[]
  timeline          LeadTimeline[]

  @@index([createdByBdId])
  @@index([assignedBdId])
  @@index([status])
}

model LeadCall {
  id                 String             @id @default(cuid())
  leadId             String
  callNumber         Int
  callStage          CallStage
  scheduledByBdId    String
  closerId           String
  scheduledAt        DateTime
  status             LeadCallStatus     @default(SCHEDULED)
  manualInviteStatus ManualInviteStatus @default(MANUAL_INVITE_PENDING)
  manualInviteLink   String?
  bdNotes            String?
  closerNotes        String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  lead               Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  scheduledByBd      User               @relation("ScheduledBdCalls", fields: [scheduledByBdId], references: [id])
  closer             User               @relation("CloserLeadCalls", fields: [closerId], references: [id])
  feedback           CallFeedback[]

  @@unique([leadId, callNumber])
  @@index([leadId])
  @@index([scheduledByBdId])
  @@index([closerId])
  @@index([status])
}

model CallFeedback {
  id               String             @id @default(cuid())
  leadCallId       String
  closerId         String
  callStatus       FeedbackCallStatus
  result           FeedbackResult
  comments         String
  payrateDiscussed String
  nextAction       String?
  nextCallRequired Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  leadCall         LeadCall           @relation(fields: [leadCallId], references: [id], onDelete: Cascade)
  closer           User               @relation(fields: [closerId], references: [id])

  @@index([leadCallId])
  @@index([closerId])
}

model LeadTimeline {
  id          String   @id @default(cuid())
  leadId      String
  actorId     String?
  action      String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())

  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actor       User?    @relation(fields: [actorId], references: [id])

  @@index([leadId])
  @@index([actorId])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User?    @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entityType])
  @@index([createdAt])
}
